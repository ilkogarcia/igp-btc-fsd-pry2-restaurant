Options -MultiViews
Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Canonical home: resolve www/index.html and /index.html in one hop.
    RewriteCond %{HTTP_HOST} ^www\.viejobarrio\.es$ [NC,OR]
    RewriteCond %{THE_REQUEST} \s/+index\.html(?:[\s?]|$) [NC]
    RewriteRule ^index\.html$ https://viejobarrio.es/ [R=301,L]

    # Canonical host for every other public URL.
    RewriteCond %{HTTP_HOST} ^www\.viejobarrio\.es$ [NC]
    RewriteRule ^ https://viejobarrio.es%{REQUEST_URI} [R=301,L]
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On

    # Keep HTML fresh while allowing browsers to reuse static assets.
    ExpiresByType text/html "access plus 0 seconds"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/jpg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType image/x-icon "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
    ExpiresByType application/pdf "access plus 1 month"
    ExpiresByType font/woff2 "access plus 1 month"
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.(css|js|jpg|jpeg|png|webp|ico|svg|pdf|woff2)$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>

    <FilesMatch "\.(html?)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
    </FilesMatch>
</IfModule>
